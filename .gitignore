# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── cheat-on-content: 凭证不提交 ──
.auth/
.auth-xhs/
.auth-linkedin/
.cheat-secrets.json

# ── cheat-on-content: 本地缓存与生成物 ──
.cheat-cache/
.cheat-hooks/
.debug/

# ── cheat-on-content: Python（adapter 工具脚本）──
__pycache__/
*.py[cod]
*$py.class
